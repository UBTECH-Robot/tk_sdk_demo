#!/bin/bash
# vglrun wrapper for ros2
# 会话级 PATH 劫持脚本，由 start_with_xvfb.sh 在启动 gnome-session 前将本目录
# 置于 PATH 头部，使 GNOME 会话内所有 ros2 调用（含终端、桌面启动器、脚本）
# 均自动经过 vglrun，从而让 OpenGL 渲染走 VirtualGL 转发到 VNC。

# 从 PATH 中移除本目录，定位真实的 ros2 可执行文件
_wrap_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_real_ros2=$(
    PATH=$(printf '%s' "$PATH" | tr ':' '\n' | grep -vxF "$_wrap_dir" | tr '\n' ':')
    command -v ros2 2>/dev/null
)
_real_ros2="${_real_ros2:-/opt/ros/humble/bin/ros2}"

if command -v vglrun >/dev/null 2>&1; then
    echo "✓ vglrun 可用，正在通过 vglrun 启动 ros2..."
    exec vglrun "$_real_ros2" "$@"
else
    echo "⚠️ vglrun 不可用，正在直接启动 ros2..."
    exec "$_real_ros2" "$@"
fi
