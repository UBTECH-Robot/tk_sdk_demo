#!/bin/bash
# vglrun wrapper for rviz2
# 会话级 PATH 劫持脚本，由 start_with_xvfb.sh 在启动 gnome-session 前将本目录
# 置于 PATH 头部，使 GNOME 会话内所有 rviz2 调用均自动经过 vglrun。

# 从 PATH 中移除本目录，定位真实的 rviz2 可执行文件
_wrap_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_real_rviz2=$(
    PATH=$(printf '%s' "$PATH" | tr ':' '\n' | grep -vxF "$_wrap_dir" | tr '\n' ':')
    command -v rviz2 2>/dev/null
)
_real_rviz2="${_real_rviz2:-/opt/ros/humble/bin/rviz2}"

if command -v vglrun >/dev/null 2>&1; then
    exec vglrun "$_real_rviz2" "$@"
else
    exec "$_real_rviz2" "$@"
fi
